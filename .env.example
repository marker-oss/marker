# Marketplace credentials for the Marker pilot. Copy to .env and fill in real
# values. .env is gitignored — NEVER commit real secrets. On the VPS: chmod 600 .env
WB_API_TOKEN=replace-with-wb-jwt
OZON_CLIENT_ID=replace-with-ozon-client-id
OZON_API_KEY=replace-with-ozon-api-key
YM_OAUTH_TOKEN=replace-with-ym-oauth-token
YM_BUSINESS_ID=replace-with-ym-business-id
YM_CAMPAIGN_ID=replace-with-ym-campaign-id
# API_KEY for X-API-Key on mutating routes (Plan A). Generate: openssl rand -hex 24
API_KEY=replace-with-random-hex
