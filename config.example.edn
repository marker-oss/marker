{:marketplaces
 {:wb {:api-token "YOUR_WB_API_TOKEN_HERE"
       :rate-limits {:statistics  1      ;; 1 req/min
                     :analytics   3      ;; 3 req/min
                     :advert      300    ;; 5 req/sec
                     :marketplace 300    ;; 5 req/sec
                     :content     100    ;; 100 req/min
                     :prices      100}}  ;; ~100 req/min

  :ozon {:client-id  "your-ozon-client-id"
         :api-key    "your-ozon-api-key"
         :rate-limits {:default 60}
         ;; Ozon Performance (advertising) creds — optional; absence disables ads.
         ;; Distinct host + OAuth (api-performance.ozon.ru). Needs BOTH parts;
         ;; a partial credential leaves the feature off (FR-005). Use #prop
         ;; (NOT #env): .env values load as JVM system properties.
         :performance {:client-id     #prop OZON_PERF_CLIENT_ID
                       :client-secret #prop OZON_PERF_CLIENT_SECRET}}

  :ym {:oauth-token "your-ym-oauth-token"
       :campaign-id "your-ym-campaign-id"
       :business-id "your-ym-business-id"
       :rate-limits {:default 600}}}

 :api-key      #prop API_KEY       ; X-API-Key for mutating routes; set API_KEY in .env (loaded as a JVM system property)
 :cors-origins ["https://marker.shegida.ru" "http://localhost:3000"]

 :cost-prices
 {:source :edn
  :path   "data/cost-prices.edn"}

 :audit
 {:tolerance {:rel 0.01   ;; 1% relative delta → classified as :expected (rounding)
              :abs 10.0}}

 ;; ---------------------------------------------------------------------------
 ;; 018-platform-seams: Telemetry (US2 T010) — optional, default OFF.
 ;; Self-host without a collector works normally (SC-005 fail-open).
 ;; Use #prop (NOT #env): .env values load as JVM system properties.
 ;; Uncomment and set OTLP_ENDPOINT in .env to enable export.
 ;; ---------------------------------------------------------------------------
 ;; :telemetry
 ;; {:enabled   #prop TELEMETRY_ENABLED    ;; "true" to enable OTLP export
 ;;  :endpoint  #prop OTLP_ENDPOINT        ;; e.g. "http://localhost:4318"
 ;;  :publisher :otlp}                     ;; pluggable; :otlp is the default

 ;; ---------------------------------------------------------------------------
 ;; 018-platform-seams: Tariffs (US4 T010) — open edition default.
 ;; The catalogue is defined as data in platform/tariffs.clj; no DB needed.
 ;; This config key reserves the namespace for future per-user entitlement.
 ;; ---------------------------------------------------------------------------
 ;; :tariffs
 ;; {:edition "free"}                      ;; "free" = open/self-host (default)
 }
