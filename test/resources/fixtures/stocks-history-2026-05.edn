  {:snapshot-date "2026-05-23" :marketplace "wb" :article "3452/Бежевый" :warehouse "FBO-Коледино" :quantity 120}
  {:snapshot-date "2026-05-24" :marketplace "wb" :article "3452/Бежевый" :warehouse "FBO-Коледино" :quantity 120}
