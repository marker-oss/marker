;; Fixture for 016-US2 capitalization / coverage-aware GMROI / turnover.
;; Period: 2026-05-01 .. 2026-05-31 (31 days).
;;
;; Two SKU (data-model §2/§3 + contracts/stock-capitalization.edn):
;;   "3452/Бежевый" — partial coverage (stock collected only SOME days of May),
;;                    HAS a cost-price → cap-by-cost + GMROI applicable.
;;   "9981/Чёрный"  — all-uncovered (NO stocks_history collected rows),
;;                    NO cost-price → cap-by-cost + GMROI :not-applicable.
;;
;; Shapes match the runtime tables (kebab, as db/query returns):
;;   :stocks         — current snapshot (carries :quantity-full incl. in-transit)
;;   :stocks-history — per-day snapshots (carry :quantity; PK snapshot_date,mp,article,warehouse)
;;   :cost-prices    — {article -> unit-cost-basis}  (cost+fulfilment+VAT scalar)
;;   :sales          — period sale rows (each carries :quantity; :type :sale)
;;   :period         — {:from :to :days}
;;   :net-profit     — {article -> MP-level net profit for the period}
;;   :expected       — precomputed invariant targets (kopeck-exact)

{:period {:from "2026-05-01" :to "2026-05-31" :days 31}

 ;; ── current stock (ties to stock/totals :total-full) ──
 :stocks
 [{:marketplace "wb" :article "3452/Бежевый" :warehouse "FBO-Коледино"
   :quantity 100 :quantity-full 100 :in-way-to 20 :in-way-from 0}
  {:marketplace "wb" :article "3452/Бежевый" :warehouse "in-transit"
   :quantity 0   :quantity-full 20  :in-way-to 20 :in-way-from 0}
  {:marketplace "wb" :article "9981/Чёрный"  :warehouse "FBO-Тула"
   :quantity 40  :quantity-full 40  :in-way-to 0  :in-way-from 0}]

 ;; ── cost prices (one SKU with, one without) ──
 ;; unit-cost-basis 590.00 for 3452; 9981 absent → nil basis → N/A
 :cost-prices {"3452/Бежевый" 590.00}

 ;; ── per-day stocks_history snapshots (COVERED days only for 3452) ──
 ;; 3452: collected on 22 of 31 days (partial coverage). qty varies day to day.
 ;;   9 days (2026-05-01..2026-05-09) have NO history row → uncovered.
 ;;   22 days (2026-05-10..2026-05-31) each have one row → covered.
 ;;   Every covered-day quantity is 120 EXCEPT one deliberate zero-stock day
 ;;   (2026-05-15 qty=0) so a toggle-test can drop/keep it.
 ;; 9981: ZERO history rows → all-uncovered.
 :stocks-history
 [{:snapshot-date "2026-05-10" :marketplace "wb" :article "3452/Бежевый" :warehouse "FBO-Коледино" :quantity 120}
  {:snapshot-date "2026-05-11" :marketplace "wb" :article "3452/Бежевый" :warehouse "FBO-Коледино" :quantity 120}
