 ;; ── period sales (for turnover Σqty) ──
 ;; 3452: ONE sale event of 5 units (FR-012: turnover must use 5 units, not 1 event).
 ;; 9981: no sales.
 :sales
 [{:marketplace "wb" :article "3452/Бежевый" :type :sale :quantity 5 :retail-amount 7450.0}]

 ;; ── MP-level net profit per article (GMROI numerator, TS def) ──
 :net-profit {"3452/Бежевый" 24500.00
              "9981/Чёрный"  nil}

 ;; ── precomputed invariant targets (kopeck-exact) ──
 :expected
 {:days-in-period      31
  ;; capitalization-by-cost = 590.00 × 120 (quantity-full: 100 + 20 in-transit)
  :cap-by-cost-3452    70800.00
  :stock-qty-3452      120
  :cap-by-cost-9981    nil
  :stock-qty-9981      40
  :cap-by-cost-total   70800.00
  :stock-qty-total     160
  :na-cost-count       1
  :sku-count           2
  ;; coverage: 22 rows present, but one (2026-05-15) is a zero-stock day.
  ;; "covered" = a day with COLLECTED (non-zero) stock → 21 covered days.
  :covered-days-3452           21
  :covered-days-3452-with-zero 22   ; if the zero-day is (wrongly) counted
  ;; daily-cap-series over 21 covered days: each 590.00 × 120 = 70800.00
  :daily-cap-3452      70800.00
  :avg-inventory-3452  70800.00
  ;; gmroi = 24500.00 / 70800.00
  :gmroi-3452          0.346
  ;; annualized = gmroi × (365 / 31)
