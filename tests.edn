#kaocha/v1
{:tests [{:id          :unit
          :test-paths  ["test"]
          ;; Exclude namespaces whose production ns does not exist yet on this
          ;; branch (loading them raises ClassNotFound / FileNotFound).
          ;; schema.performance-test → spec 001 (registry/validator)
          ;; feedback-notify-test   → analitica.feedback.notify (future task)
          ;; Once the production ns lands, remove the corresponding exclusion.
          :ns-patterns ["^(?!.*schema\\.performance-test$)(?!.*feedback-notify-test$).*-test$"]
          ;; Skip tests tagged ^:integration by default. These require an
          ;; isolated test database (ANALITICA_DB=test-analitica.db) and
          ;; populated fixtures. Run with `--no-skip-meta :integration` to
          ;; include them.
          :skip-meta   [:integration]}]}
